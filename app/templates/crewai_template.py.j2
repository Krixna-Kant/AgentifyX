"""Auto-generated by AgentifyX — CrewAI Agentic Architecture
Document: {{ roster.document_name }}
Composite Readiness Score: {{ "%.1f"|format(roster.composite_readiness) }}/100
Recommended Framework: {{ roster.recommended_framework }}
Transformation Summary: {{ roster.transformation_summary }}
"""

from crewai import Agent, Task, Crew, Process

{% for agent in roster.agents %}
# ─── {{ agent.agent_name }} ────────────────────────────────────────
{{ agent.agent_id | replace("-", "_") }}_agent = Agent(
    role="{{ agent.role }}",
    goal="{{ agent.goal }}",
    backstory=(
        "You are a senior {{ agent.role }}. "
        "You execute your goals flawlessly with high precision."
    ),
    verbose=True,
    allow_delegation=False,
    # Tools needed: {{ agent.tools_required | join(", ") }}
    {% if agent.hitl_required %}# ⚠️ HITL REQUIRED — Checkpoints: {{ agent.hitl_checkpoints | join(", ") }}
    {% endif %}
)

{{ agent.agent_id | replace("-", "_") }}_task = Task(
    description=(
        "{{ agent.goal }} "
        "Use inputs from: {{ agent.input_sources | join(', ') }}. "
        "Produce: {{ agent.output_artifacts | join(', ') }}."
    ),
    expected_output="{{ agent.output_artifacts | join(', ') if agent.output_artifacts else 'Task completion report' }}",
    agent={{ agent.agent_id | replace("-", "_") }}_agent,
)

{% endfor %}

# ─── Assemble the Crew ─────────────────────────────────────────────
agentifyx_crew = Crew(
    agents=[
        {% for agent in roster.agents %}{{ agent.agent_id | replace("-", "_") }}_agent,
        {% endfor %}
    ],
    tasks=[
        {% for agent in roster.agents %}{{ agent.agent_id | replace("-", "_") }}_task,
        {% endfor %}
    ],
    process=Process.sequential,
    verbose=True,
)


if __name__ == "__main__":
    print("Starting AgentifyX Crew...")
    result = agentifyx_crew.kickoff()
    print(result)

# ─── Human Review Node ─────────────────────────────────────────────
def human_review_node(state: AgentState) -> AgentState:
    """Human-in-the-loop review checkpoint."""
    print(f"[HITL] Agent '{state['current_agent']}' requires human review.")
    # In production, this would use interrupt() for async human input
    # from langgraph.types import interrupt
    # feedback = interrupt("Please review the agent output and provide feedback.")
    return {**state, "needs_human_review": False, "human_feedback": "approved"}


# ─── Routing Logic ─────────────────────────────────────────────────
def should_review(state: AgentState) -> str:
    if state.get("needs_human_review", False):
        return "human_review"
    return "continue"


# ─── Build the Graph ───────────────────────────────────────────────
workflow = StateGraph(AgentState)

{% for agent in roster.agents %}
workflow.add_node("{{ agent.agent_id }}", {{ agent.agent_id | replace("-", "_") }}_node)
{% endfor %}
workflow.add_node("human_review", human_review_node)

# Set entry point
{% if roster.agents %}
workflow.set_entry_point("{{ roster.agents[0].agent_id }}")
{% endif %}

# Add edges
{% for agent in roster.agents %}
{% if agent.hitl_required %}
workflow.add_conditional_edges(
    "{{ agent.agent_id }}",
    should_review,
    {"human_review": "human_review", "continue": "{% if not loop.last %}{{ roster.agents[loop.index].agent_id }}{% else %}END{% endif %}"},
)
workflow.add_edge("human_review", "{% if not loop.last %}{{ roster.agents[loop.index].agent_id }}{% else %}END{% endif %}")
{% else %}
{% if not loop.last %}

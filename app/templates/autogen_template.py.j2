"""Auto-generated by AgentifyX — AutoGen Agentic Architecture
Document: {{ roster.document_name }}
Composite Readiness Score: {{ "%.1f"|format(roster.composite_readiness) }}/100
Recommended Framework: {{ roster.recommended_framework }}
Transformation Summary: {{ roster.transformation_summary }}
"""

from autogen import AssistantAgent, UserProxyAgent, GroupChat, GroupChatManager


# ─── LLM Configuration ────────────────────────────────────────────
llm_config = {
    "config_list": [
        {
            "model": "gemini-2.0-flash",
            "api_key": "YOUR_API_KEY",
            "api_type": "google",
        }
    ],
    "temperature": 0.3,
}


{% for agent in roster.agents %}
# ─── {{ agent.agent_name }} ────────────────────────────────────────
{{ agent.agent_id | replace("-", "_") }}_agent = AssistantAgent(
    name="{{ agent.agent_id | replace('-', '_') }}",
    system_message=(
        "You are {{ agent.agent_name }}, a {{ agent.role }}. "
        "Your goal: {{ agent.goal }}. "
        "Tools available: {{ agent.tools_required | join(', ') }}. "
        "Input sources: {{ agent.input_sources | join(', ') }}. "
        "Expected outputs: {{ agent.output_artifacts | join(', ') }}."
        {% if agent.hitl_required %}
        " IMPORTANT: You must request human approval at these checkpoints: "
        "{{ agent.hitl_checkpoints | join(', ') }}."
        {% endif %}
    ),
    llm_config=llm_config,
)

{% endfor %}

# ─── Human Proxy Agent (for HITL interactions) ─────────────────────
user_proxy = UserProxyAgent(
    name="human_overseer",
    human_input_mode="TERMINATE",  # Change to "ALWAYS" for full HITL
    max_consecutive_auto_reply=10,
    code_execution_config={"work_dir": "workspace", "use_docker": False},
)


# ─── Group Chat Setup ─────────────────────────────────────────────
group_chat = GroupChat(
    agents=[
        user_proxy,
        {% for agent in roster.agents %}{{ agent.agent_id | replace("-", "_") }}_agent,
        {% endfor %}
    ],
    messages=[],
    max_round=50,
)

manager = GroupChatManager(
    groupchat=group_chat,
    llm_config=llm_config,
)


if __name__ == "__main__":
    print("Starting AgentifyX AutoGen Group Chat...")
    user_proxy.initiate_chat(
        manager,
        message=(
            "Analyze the legacy system documentation and coordinate "
            "all agents to produce the transformation blueprint."
        ),
    )
